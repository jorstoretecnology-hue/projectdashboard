# Entorno de Next.js
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Supabase
# Obtener de: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App
NEXT_PUBLIC_APP_NAME=Dashboard Universal
NEXT_PUBLIC_DEFAULT_THEME=system

# API
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Feature flags
NEXT_PUBLIC_FEATURE_EXAMPLE=false

# Mercado Pago
NEXT_PUBLIC_MP_PUBLIC_KEY=your-mp-public-key-here
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token-here

# DIAN / Facturación Electrónica (Alegra)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
