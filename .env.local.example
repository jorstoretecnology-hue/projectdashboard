# ==========================================
# Supabase
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==========================================
# n8n Integration
# ==========================================
# URL base de n8n (local)
N8N_HOST=http://localhost:5678
# URL pública de n8n (Ngrok) para webhooks
N8N_WEBHOOK_URL=https://cauline-lacey-tempered.ngrok-free.dev
# API Key de n8n - Generar en: n8n > Settings > API > Create API Key
N8N_API_KEY=your-n8n-api-key-here
# Ngrok Auth Token para el túnel
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
