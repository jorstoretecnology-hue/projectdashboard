## 📋 Configuración Global

```json
{
  "version": "1.0.0",
  "project": {
    "name": "Dashboard Universal SaaS",
    "type": "nextjs-supabase-saas",
    "multiTenant": true,
    "authProvider": "supabase"
  },
  "rules": {
    "security": {
      "enforceRLS": true,
      "blockSelectStar": true,
      "requireZodValidation": true,
      "blockAnyType": true,
      "blockConsoleLogInProd": true
    },
    "architecture": {
      "enforceTenantIsolation": true,
      "requireModuleActivation": true,
      "enforceRoleBasedAccess": true
    },
    "code": {
      "strictTypeScript": true,
      "requireErrorHandling": true,
      "requireLoadingStates": true
    }
  },
  "integrations": {
    "qwen": {
      "enabled": true,
      "role": "cli-validator",
      "commands": ["npm run check", "npm run security:audit"]
    },
    "sentry": {
      "enabled": true,
      "role": "error-tracking"
    }
  },
  "channels": {
    "security": "#security-pipeline",
    "coordination": "#ai-coordination"
  }
}
```

